@model List<Wallet>
<!doctype html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>@ViewBag.Title</title>
  <link href="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.css" rel="stylesheet" />
</head>
<body style="background-color: black; margin: 0;">
  <main class="p-6">
    <div class="mt-10 px-6 w-full max-w-5xl mx-auto">
      <h3 class="text-2xl font-bold text-white mb-6">Wallets</h3>

      <div class="bg-gray-800 p-6 rounded-lg shadow-lg overflow-x-auto">
        <table class="table-auto w-full text-left text-white border-collapse">
          <thead class="bg-gray-700 text-sm">
            <tr>
              <th class="p-4 border-b border-gray-600">Wallet Name</th>
              <th class="p-4 border-b border-gray-600">Wallet Address</th>
              <th class="p-4 border-b border-gray-600 text-center">Action</th>
            </tr>
          </thead>

          <tbody class="text-sm">
            @foreach(var wallet in Model)
            {
              <tr class="border-t border-gray-700 hover:bg-gray-700 transition">

              <td class="p-4">@wallet.WalletName</td>
              <td class="p-4 break-all">@wallet.WalletAddress</td>
              <td class="p-4 text-center">
                <a href="@Url.Action("DeleteWallet","Account", new {walletId = wallet.WalletId})" class="bg-red-500 hover:bg-red-600 text-white px-4 py-1 rounded-md text-sm">Delete</a>
              </td>
            </tr>
            }           
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>
</html>
